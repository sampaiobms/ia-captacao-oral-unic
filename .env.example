# ============================================================
# IA CAPTACAO ORAL UNIC — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais
# NUNCA commite o arquivo .env
# ============================================================

# ------------------------------------------------------------
# FLOWISE
# ------------------------------------------------------------
FLOWISE_USERNAME=
FLOWISE_PASSWORD=
FLOWISE_URL=https://flowise-production-5edd.up.railway.app

# ------------------------------------------------------------
# OPENAI
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# N8N
# ------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_ENCRYPTION_KEY=
N8N_PROTOCOL=https
N8N_PORT=8080
N8N_LISTEN_ADDRESS=0.0.0.0
WEBHOOK_URL=https://n8n-lead-production.up.railway.app/
N8N_EDITOR_BASE_URL=https://n8n-lead-production.up.railway.app/

# ------------------------------------------------------------
# EVOLUTION API
# Versão: v1.8.2 (USAR ESTA — v2.x tem bugs no Baileys)
# Porta Railway: sempre 8080
# ------------------------------------------------------------
EVOLUTION_API_URL=https://evolution-api-production-cedd.up.railway.app
EVOLUTION_API_KEY=
SERVER_PORT=8080
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
DATABASE_ENABLED=true
DATABASE_PROVIDER=mysql
DATABASE_CONNECTION_URI=
QRCODE_LIMIT=30
DEL_INSTANCE=false
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=
CACHE_REDIS_PREFIX_KEY=evolution

# ------------------------------------------------------------
# SUPABASE — Banco Principal (leads, KPIs)
# Plano recomendado: Pro ($25/mes) — porta 5432 liberada
# No plano FREE usar pooler na porta 6543 (tem delay)
# ------------------------------------------------------------
SUPABASE_URL=https://btighfgcablumcjacssz.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
# Conexão direta (Pro): postgresql://postgres:<senha>@db.btighfgcablumcjacssz.supabase.co:5432/postgres
# Pooler (FREE):        postgresql://postgres:<senha>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ------------------------------------------------------------
# MYSQL — Banco Evolution API
# Host externo Railway (proxy público)
# Senhas sem caracteres especiais (#, @, !) — Railway quebra ENV
# ------------------------------------------------------------
MYSQL_HOST=shortline.proxy.rlwy.net
MYSQL_PORT=39145
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=railway
MYSQL_URI=

# ------------------------------------------------------------
# REDIS
# URI interna Railway (apenas serviços no mesmo projeto)
# ------------------------------------------------------------
REDIS_URI=

# ------------------------------------------------------------
# GOOGLE CALENDAR
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# ------------------------------------------------------------
# GEMINI (IA backup — follow-ups frequentes)
# ------------------------------------------------------------
GEMINI_API_KEY=
