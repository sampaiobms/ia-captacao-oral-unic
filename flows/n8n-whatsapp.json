      "typeVersion": 4.2,
      "position": [960, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://btighfgcablumcjacssz.supabase.co/rest/v1/leads?telefone=eq.{{ encodeURIComponent($('Normalizar Dados').item.json.telefone) }}&select=id,nome,status,score_qualificacao",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SUPABASE_SERVICE_KEY }}"
