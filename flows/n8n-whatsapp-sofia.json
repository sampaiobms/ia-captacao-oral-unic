    {
      "parameters": {
        "method": "GET",
        "url": "https://evolution-api-production-cedd.up.railway.app/contact/findContacts/oral-unic",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "A433F7FD-5F57-4C9B-9FED-8910E0401744" }
          ]
