        "options": {}
      },
      "id": "n9-send-msg",
      "name": "Enviar Mensagem WA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 280],
      "notes": "Instance Key já configurada. Delay 5000ms simula digitação humana."
    }
