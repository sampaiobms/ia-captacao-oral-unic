      "id": "n-resolver-telefone",
      "name": "Resolver Telefone",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 280],
      "notes": "Busca o contato pelo @lid para obter o número real de telefone. Se falhar, o próximo nó usa fallback."
    },
    {
      "parameters": {
        "jsCode": "// Resolver @lid → número real de telefone via Evolution API contacts\nconst resp = $input.first().json;\n\n// A resposta pode ser array direto ou { data: [...] }\nlet contacts = [];\nif (Array.isArray(resp)) {\n  contacts = resp;\n} else if (resp.body && Array.isArray(resp.body)) {\n  contacts = resp.body;\n} else if (Array.isArray(resp.data)) {\n  contacts = resp.data;\n} else if (resp.id) {\n  contacts = [resp];\n}\n\nconst jidAlvo = $('Normalizar Dados').item.json.jid_completo;\n\n// Procurar contato cujo id bate com o @lid\nconst contato = contacts.find(c => c.id === jidAlvo || c.remoteJid === jidAlvo) || contacts[0] || {};\n\n// O campo 'id' do contato deve ser o JID real (ex: 5511968404390@s.whatsapp.net)\nconst jidReal = contato.id || contato.remoteJid || contato.jid || '';\n\nlet telefone;\nif (jidReal.includes('@s.whatsapp.net')) {\n  // Caso ideal: @s.whatsapp.net → extrair só o número\n  telefone = jidReal.replace('@s.whatsapp.net', '');\n} else if (jidReal.includes('@lid')) {\n  // Contato ainda em @lid: não resolvido, usar sem sufixo (enviará erro adiante)\n  telefone = jidReal.replace('@lid', '');\n  // NOTA: neste caso a Evolution API ainda vai recusar — @lid nativo do WA\n} else if (jidReal) {\n  telefone = jidReal.split('@')[0];\n} else {\n  // Fallback extremo: usar o @lid sem sufixo (melhor que nada)\n  telefone = jidAlvo.split('@')[0];\n}\n\nconst n = $('Normalizar Dados').item.json;\nreturn [{\n  json: {\n    ...n,\n    telefone,\n    telefone_jid_resolvido: jidReal,\n    telefone_jid_original: jidAlvo\n  }\n}];"
      },
      "id": "n-extrair-numero",
      "name": "Extrair Número Real",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 280],
      "notes": "Extrai o número limpo do retorno da API de contatos. Se o @lid não resolver, telefone_jid_resolvido ficará vazio — verificar logs."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://btighfgcablumcjacssz.supabase.co/rest/v1/leads",
        "sendHeaders": true,
