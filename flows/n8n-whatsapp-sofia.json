    {
      "parameters": {
        "method": "POST",
        "url": "https://flowise-production-5edd.up.railway.app/api/v1/prediction/5814b9c2-c9a8-4273-a3e1-bacf91bb91ff",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ question: $('Extrair Número Real').item.json.mensagem_lead, overrideConfig: { sessionId: $('Extrair Número Real').item.json.telefone } }) }}",
        "options": {}
      },
      "id": "n5-flowise",
      "name": "Chamar Sofia",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 280]
    },
    {
      "parameters": {
        "jsCode": "// Parsear JSON retornado pela Sofia (campo 'text' do Flowise)\nconst raw = $input.first().json.text || '';\nlet sofia;\ntry {\n  const clean = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  sofia = JSON.parse(clean);\n} catch (e) {\n  sofia = {\n    mensagem: raw || 'Olá! Como posso ajudar?',\n    intencao: 'desconhecido',\n    score: 0,\n    status: 'frio',\n    proximo_passo: 'followup'\n  };\n}\n\nconst lead = $('Upsert Lead').item.json;\nconst leadArray = Array.isArray(lead) ? lead : [lead];\nconst nr = $('Extrair Número Real').item.json;\n\nreturn [{\n  json: {\n    ...sofia,\n    telefone:      nr.telefone,\n    nome:          nr.nome,\n    mensagem_lead: nr.mensagem_lead,\n    lead_id:       leadArray[0]?.id ?? null\n  }\n}];"
      },
