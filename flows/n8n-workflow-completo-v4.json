    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const raw = $input.first().json.text || '';\nlet sofia;\ntry {\n  const clean = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  sofia = JSON.parse(clean);\n} catch (e) {\n  sofia = {\n    mensagem: raw || 'Olá! Como posso ajudar?',\n    intencao: 'desconhecido',\n    score: 0,\n    status: 'frio',\n    proximo_passo: 'followup',\n    dor: false,\n    agendamento_confirmado: false,\n    agendamento_horario: ''\n  };\n}\n\nconst lead = $('Upsert Lead').item.json;\nconst leadArray = Array.isArray(lead) ? lead : [lead];\nconst nr = $('Normalizar Dados').item.json;\n\nreturn [{\n  json: {\n    ...sofia,\n    telefone:      nr.telefone,\n    nome:          nr.nome,\n    mensagem_lead: nr.mensagem,\n    lead_id:       leadArray[0]?.id ?? null\n  }\n}];"
      },
